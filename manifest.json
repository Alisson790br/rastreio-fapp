{
    "manifest_version": 3,
    "name": "Rastreio FAPP",
    "version": "1.1.2",
    "description": "Busque rastreios de pedidos pelo numero, sincronize do SharePoint, copie codigo e link e abra a transportadora.",
    "permissions": [
          "storage"
    ],
    "host_permissions": [
          "https://*.sharepoint.com/*",
          "https://*.sharepointonline.com/*"
    ],
    "action": {
          "default_popup": "popup.html",
          "default_title": "Rastreio FAPP",
          "default_icon": {
                  "16": "icons/icon16.png",
                  "32": "icons/icon32.png",
                  "48": "icons/icon48.png",
                  "128": "icons/icon128.png"
          }
    },
    "icons": {
          "16": "icons/icon16.png",
          "32": "icons/icon32.png",
          "48": "icons/icon48.png",
          "128": "icons/icon128.png"
    }
}
